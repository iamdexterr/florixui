{
  "name": "florixui",
  "private": false,
  "version": "1.3.1",
  "type": "module",
  "description": "A React component library built on shadcn/ui and Tailwind CSS.",
  "license": "MIT",
  "homepage": "https://florixui.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamdexterr/florixui.git"
  },
  "bugs": {
    "url": "https://github.com/iamdexterr/florixui/issues"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "component-library",
    "shadcn",
    "tailwind",
    "design-system"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite",
    "docs:dev": "vite",
    "docs:build": "tsc -b && vite build",
    "docs:preview": "vite preview --outDir dist-docs",
    "build": "tsc -b && vite build",
    "build:js": "LIB_BUILD=js vite build",
    "build:css": "LIB_BUILD=css vite build",
    "build:lib": "npm run build:js && npm run build:css",
    "docs:readme": "node scripts/gen-readme-components.mjs",
    "prepublishOnly": "npm run docs:readme && npm run build:lib",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.3.0",
    "lucide-react": "^1.17.0",
    "maplibre-gl": "^5.24.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/roboto-mono": "^5.2.9",
    "@fontsource/dm-mono": "^5.2.7",
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/dm-serif-text": "^5.2.8",
    "@fontsource/merriweather": "^5.2.11",
    "@fontsource/noto-serif-georgian": "^5.2.9",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.8.3",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.1"
  }
}
